{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "embeddedLanguageFormatting": "auto",
  "ignorePatterns": [
    "dist/**",
    "dev-dist/**",
    ".local/**",
    ".claude/**",
    ".agent/**",
    ".agents/**",
    ".codex/**",
    ".output.js",
    "node_modules/**",
    "coverage/**",
    ".nitro/**",
    ".output/**",
    "**/*.svg",
    "**/*.sh",
    "public/**",
    ".npmrc",
    "*-lock.yaml",
    "skills-lock.json",
  ],
}
