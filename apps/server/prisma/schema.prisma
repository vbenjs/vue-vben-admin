}

/// 角色-菜单关联表
model SysRoleMenu {
  roleId Int @map("role_id")
  menuId Int @map("menu_id")

  @@id([roleId, menuId])
  @@map("sys_role_menu")
}

/// 用户-角色关联表
model SysUserRole {
  userId BigInt @map("user_id")
  roleId Int    @map("role_id")

  @@id([userId, roleId])
  @@map("sys_user_role")
}

